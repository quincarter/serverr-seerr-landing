---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactCTA from '../components/ContactCTA.astro';
---

<BaseLayout title="About | ServerrSeerr" description="Learn more about ServerrSeerr and the vision behind it.">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About ServerrSeerr"
				tagline="The mission to bring your media management everywhere."
			>
				<img
					width="1553"
					height="873"
					src="/assets/stock-3.jpg"
					alt="ServerrSeerr in action"
				/>
			</Hero>

			<section>
				<h2 class="section-title">The Vision</h2>
				<div class="content">
					<p>
						ServerrSeerr was born out of a simple need: managing media requests on the go shouldn't be a chore.
						We believe in high-quality, native mobile experiences that complement the powerful tools like Overseerr and Jellyseerr.
					</p>
					<p>
						Our goal is to provide a fast, intuitive, and beautiful interface that makes requesting media as simple as a few taps on your phone.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Mentality</h2>
				<div class="content">
					<p>
						ServerrSeerr has been a hobby project that a single dev has been working on. I firmly believe that ServerrSeerr enables you to have your self-hosted content in the palm of your hand, or on the big screen. 
					</p>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		border: 1px solid var(--gray-800);
		background: var(--gradient-subtle);
		padding: 0.5rem;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content p {
		margin-bottom: 1.5rem;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
